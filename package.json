{
  "name": "lsjs-sacks",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "moon run :dev",
    "build": "moon run :build",
    "check": "moon check",
    "prisma:generate": "npm --workspace @lsjs-sacks/backend run prisma:generate",
    "prisma:migrate": "npm --workspace @lsjs-sacks/backend run prisma:migrate"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": "10.9.2"
  }
}
